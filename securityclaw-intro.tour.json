    {
      "id": "welcome-overview",
      "title": "Welcome to SecurityClaw",
      "description": "SecurityClaw is a modular SOC agent framework with real-time anomaly monitoring, LLM-powered threat analysis, and a skill-based plugin architecture. The codebase is organized into four main areas: the core framework, modular skills, a React web interface, and a comprehensive test suite.",
